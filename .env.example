# ── Configuração do Servidor de Painel Cercal ──────────────────
# Copie este arquivo como .env e preencha os valores

# Porta HTTP (o Render define automaticamente via variável PORT)
# PORT=3000

# Token de autorização para forçar atualização via botão no painel
# Deve coincidir com API_TOKEN no painel.html (variável JS API_TOKEN)
API_TOKEN=cercal2024

# Intervalo de atualização automática em minutos (padrão: 10)
INTERVALO=10

# ── Credenciais Fusion DMS (para autoLogin, se necessário) ─────
# Estas são usadas pelo fusionService existente no bot
# O sacService usa o mesmo fusion_cookie.txt
FUSION_USER=cdaalimentos.monitoramento
FUSION_PASS=Cdamonitoramento3744
